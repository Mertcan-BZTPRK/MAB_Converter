<Window x:Class="MAB_Converter.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mesaj" Width="450" MinHeight="200" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" Topmost="True">

    <Window.Resources>
        <SolidColorBrush x:Key="BgColor" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TextColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentColor" Color="#4CAF50"/>

        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgColor}" CornerRadius="12" BorderBrush="{DynamicResource AccentColor}" BorderThickness="1.5">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtTitle" Text="Bilgi" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource AccentColor}" Margin="0,0,0,15"/>

            <TextBlock x:Name="txtMessage" Grid.Row="1" Text="Mesaj içeriği buraya gelecek." TextWrapping="Wrap" Foreground="{DynamicResource TextColor}" FontSize="14" Margin="0,0,0,25" LineHeight="20"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnOpenFolder" Content="KLASÖRÜ AÇ" Width="110" Height="35" Margin="0,0,10,0" Style="{StaticResource GlassButton}" Click="BtnOpenFolder_Click" Visibility="Collapsed"/>

                <Button Content="TAMAM" Width="90" Height="35" Style="{StaticResource GlassButton}" Click="BtnOk_Click" Background="{DynamicResource AccentColor}" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>